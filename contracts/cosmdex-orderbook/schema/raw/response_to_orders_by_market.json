{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrdersResponse",
  "type": "object",
  "required": [
    "orders"
  ],
  "properties": {
    "orders": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/OrderResponse"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "AssetInfo": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "native_token"
          ],
          "properties": {
            "native_token": {
              "type": "object",
              "required": [
                "denom"
              ],
              "properties": {
                "denom": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "token"
          ],
          "properties": {
            "token": {
              "type": "object",
              "required": [
                "contract_addr"
              ],
              "properties": {
                "contract_addr": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "OrderResponse": {
      "type": "object",
      "required": [
        "base_asset",
        "created_at",
        "escrowed_amount",
        "id",
        "market_key",
        "original_base_amount",
        "owner",
        "price_denom",
        "price_num",
        "quote_asset",
        "remaining_base_amount",
        "side",
        "status",
        "updated_at"
      ],
      "properties": {
        "base_asset": {
          "$ref": "#/definitions/AssetInfo"
        },
        "created_at": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "escrowed_amount": {
          "$ref": "#/definitions/Uint128"
        },
        "id": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "market_key": {
          "type": "string"
        },
        "original_base_amount": {
          "$ref": "#/definitions/Uint128"
        },
        "owner": {
          "type": "string"
        },
        "price_denom": {
          "$ref": "#/definitions/Uint128"
        },
        "price_num": {
          "$ref": "#/definitions/Uint128"
        },
        "quote_asset": {
          "$ref": "#/definitions/AssetInfo"
        },
        "remaining_base_amount": {
          "$ref": "#/definitions/Uint128"
        },
        "side": {
          "$ref": "#/definitions/OrderSide"
        },
        "status": {
          "$ref": "#/definitions/OrderStatus"
        },
        "updated_at": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "OrderSide": {
      "type": "string",
      "enum": [
        "buy",
        "sell"
      ]
    },
    "OrderStatus": {
      "type": "string",
      "enum": [
        "open",
        "partially_filled",
        "filled",
        "cancelled"
      ]
    },
    "Uint128": {
      "description": "A thin wrapper around u128 that is using strings for JSON encoding/decoding, such that the full u128 range can be used for clients that convert JSON numbers to floats, like JavaScript and jq.\n\n# Examples\n\nUse `from` to create instances of this and `u128` to get the value out:\n\n``` # use cosmwasm_std::Uint128; let a = Uint128::from(123u128); assert_eq!(a.u128(), 123);\n\nlet b = Uint128::from(42u64); assert_eq!(b.u128(), 42);\n\nlet c = Uint128::from(70u32); assert_eq!(c.u128(), 70); ```",
      "type": "string"
    }
  }
}
